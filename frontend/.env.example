# FlowPilot AI — Frontend Client Environment Variables Template
# Copy this file locally to '.env' and configure according to target host conditions.

# 1. API Gateway Target Context
# Maps standard local dev, container, or production port gateways.
VITE_API_URL=http://localhost:8000/api/v1

# 2. Application Metadata Properties
VITE_APP_NAME="FlowPilot AI"
VITE_APP_VERSION=1.0.0

# 3. Running Environment Profile
# Supported targets: "development" | "testing" | "staging" | "production"
VITE_ENVIRONMENT=development
